{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cloudflare-nextjs",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-29",
  "keep_vars": true,
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
