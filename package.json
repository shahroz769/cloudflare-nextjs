{
  "name": "kifayatly-next",
  "version": "0.1.0",
  "private": true,
  "adapter": "@opennextjs/cloudflare",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node -e \"if (process.platform === 'win32') { console.log('Skipping OpenNext postbuild on Windows.'); } else { require('node:child_process').execSync('opennextjs-cloudflare build --skipNextBuild', { stdio: 'inherit', shell: true }); }\"",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel": "^9.0.0-rc01",
    "embla-carousel-autoplay": "^9.0.0-rc01",
    "embla-carousel-react": "^9.0.0-rc01",
    "exceljs": "^4.4.0",
