    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.0.1",
    "mongodb": "^7.1.0",
    "mongoose": "^9.3.1",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "nextjs-toploader": "^3.9.17",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  }
